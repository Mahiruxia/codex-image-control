{
  "mcpServers": {
    "image-control": {
      "command": "node",
      "args": [
        "runtime/index.js",
        "--stdio"
      ],
      "cwd": ".",
      "env": {
        "IMAGE_CONTROL_ROOT": "."
      },
      "env_vars": [
        "IMAGE_CONTROL_STATE_ROOT",
        "IMAGE_CONTROL_PROJECTS_ROOT"
      ]
    }
  }
}
