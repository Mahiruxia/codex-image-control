{
  "name": "image-control-server",
  "version": "0.11.1",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "os": [
    "win32"
  ],
  "cpu": [
    "x64"
  ],
  "scripts": {
    "dev": "tsx src/index.ts --http",
    "build": "tsc -p tsconfig.json",
    "bundle": "node ../scripts/build-runtime.mjs",
    "start": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http",
    "test": "npm run build && node --test --test-force-exit --test-timeout=30000 --test-concurrency=1 dist/store.test.js dist/video-worker.test.js dist/video-providers.test.js dist/mcp.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@napi-rs/keyring": "^1.3.0",
    "express": "^5.1.0",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^26.1.1",
    "@vercel/ncc": "^0.44.1",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2"
  }
}
